# Server Config
PORT=5000
NODE_ENV=development

# Database Config (PostgreSQL connection string)
# Replace with Neon, Supabase, or local PG URI
DATABASE_URL="postgresql://postgres:password@localhost:5432/slayr_db?schema=public"

# Redis Cache Config (Replace with your local or Upstash Redis URL)
REDIS_URL="redis://localhost:6379"

# AI Key Config
VITE_GEMINI_API_KEY="your-google-gemini-api-key-here"

# Security Token Auth
JWT_SECRET="your-jwt-auth-secret-key-here"
